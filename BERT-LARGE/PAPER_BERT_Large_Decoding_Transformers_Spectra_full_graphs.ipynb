      "outputs": [\
        \{\
          "output_type": "stream",\
          "name": "stdout",\
          "text": [\
            "[STATS] Done. Matrices processed: 148\\n",\
            "====================================================\\n",\
            "\uc0\u9989  WMP saved: 148 | Skipped (non-2D): 0\\n",\
            "====================================================\\n"\
          ]\
        \}\
      ],\
      "source": [\
        "# =========================\\n",\
        "# Build WMP and save stats for inversion\\n",\
        "# =========================\\n",\
        "import json, re, numpy as np\\n",\
        "from pathlib import Path\\n",\
        "from datetime import datetime, UTC\\n",\
        "\\n",\
        "WEIGHTS_DIR = \\"bert_large_weights\\"\\n",\
        "WMP_DIR     = \\"bert_large_weights_WMP\\"\\n",\
        "\\n",\
        "def _load_matrix(path: Path) -> np.ndarray:\\n",\
        "    return np.load(path) if path.suffix == \\".npy\\" else np.load(path)[\\"data\\"]\\n",\
        "\\n",\
        "weights_dir = Path(WEIGHTS_DIR)\\n",\
        "with open(weights_dir / \\"manifest.json\\", \\"r\\") as f:\\n",\
        "    manifest = json.load(f)\\n",\
        "\\n",\
        "processed = 0\\n",\
        "for entry in manifest.get(\\"files\\", []):\\n",\
        "    W = _load_matrix(weights_dir / entry[\\"path\\"]).astype(np.float64)\\n",\
        "    if W.ndim != 2: continue\\n",\
        "\\n",\
        "    mu, sd = W.mean(axis=0), W.std(axis=0)\\n",\
        "    safe_sd = np.where(sd == 0, 1.0, sd)\\n",\
        "    WMP = (W - mu.reshape(1, -1)) / safe_sd.reshape(1, -1)\\n",\
        "\\n",\
        "    dst = Path(WMP_DIR) / entry[\\"path\\"]\\n",\
        "    dst.parent.mkdir(parents=True, exist_ok=True)\\n",\
        "    np.save(dst, WMP)\\n",\
        "    processed += 1\\n",\
        "\\n",\
        "print(f\\"[STATS] Done. Matrices processed: \{processed\}\\")\\n"\
      ]\
    \},\
