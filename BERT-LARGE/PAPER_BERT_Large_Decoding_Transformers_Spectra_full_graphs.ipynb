            "  encoder.layer.0.attention.self.key.weight                               shape=[1024, 1024]\\n",\
            "  encoder.layer.0.attention.self.query.weight                             shape=[1024, 1024]\\n",\
            "  encoder.layer.0.attention.self.value.weight                             shape=[1024, 1024]\\n",\
            "  encoder.layer.0.intermediate.dense.weight                               shape=[4096, 1024]\\n",\
            "  encoder.layer.0.output.dense.weight                                     shape=[1024, 4096]\\n",\
            "  ...\\n",\
